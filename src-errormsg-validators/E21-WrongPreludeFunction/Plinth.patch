@@ -113,3 +113,12 @@
 plinthVotingScript :: Script
 plinthVotingScript =
   compiledCodeToScript $ plinthc mkVotingValidator
+
+-- BUG: custom SOP list + a call to PlutusTx.Prelude.length, whose only
+-- signature is `[a] -> Integer`. The mismatch fires the E21 diagnostic.
+data UserList a
+  = UNil
+  | UCons a (UserList a)
+
+userListLength :: UserList Integer -> Integer
+userListLength xs = length xs
