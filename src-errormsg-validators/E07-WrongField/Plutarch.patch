# source: src/Vesting/Contracts/Vesting.hs
#
# Bug: the record-pattern destructure of the own input's TxOut swaps the
# two bindings — local name `ptxOut'value` is bound to field
# `ptxOut'address` (Term s PAddress) and `ptxOut'address` to the value
# field (Term s (PAsData (PValue …))). The later `pfromData ptxOut'value`
# and `pgetOutputsByAddress # … # ptxOut'address` calls then cross types
# in opposite directions and produce two symmetric "Couldn't match"
# diagnostics.
#
# Apply with:
#   cp <repo>/src/Vesting/Contracts/Vesting.hs <case>/Plutarch.hs
#   (cd <case> && patch -p1 < Plutarch.patch)
#
--- a/Plutarch.hs
+++ b/Plutarch.hs
@@ -203,7 +203,7 @@
                         PTxInInfo{ptxInInfo'resolved} <-
                           pmatchC (pfindOwnInput # inputs # ownRef)
                         ownResolved <- pletC ptxInInfo'resolved
-                        PTxOut{ptxOut'address, ptxOut'value} <- pmatchC ownResolved
+                        PTxOut{ptxOut'address = ptxOut'value, ptxOut'value = ptxOut'address} <- pmatchC ownResolved
                         contractAmount <-
                           pletC (pgetLovelaceAmount # pfromData ptxOut'value)
                         PRelease declaredAmountData <- pmatchC redeemer
