# source: src/Vesting/Contracts/VestingPlinth.hs
#
# Bug: positional TxOut destructure swaps the two field names. `ownValue`
# is now bound to the Address, `ownAddress` to the Value, so the later
# `getLovelaceAmount ownValue` and `getOutputsByAddress … ownAddress`
# calls cross types in opposite directions and GHC emits two symmetric
# "Couldn't match" diagnostics.
#
# Apply with:
#   cp <repo>/src/Vesting/Contracts/VestingPlinth.hs <case>/Plinth.hs
#   (cd <case> && patch -p1 < Plinth.patch)
#
--- a/Plinth.hs
+++ b/Plinth.hs
@@ -186,7 +186,7 @@
     if mustBeSignedBy sigs beneficiary
       && let ownInput = findOwnInput ownRef inputs
              ownResolved = txInInfoResolved ownInput
-             TxOut ownAddress ownValue _ _ = ownResolved
+             TxOut ownValue ownAddress _ _ = ownResolved
              contractAmount = getLovelaceAmount ownValue
              txEarliestTime = getEarliestTime validRange
              released = amount - contractAmount
