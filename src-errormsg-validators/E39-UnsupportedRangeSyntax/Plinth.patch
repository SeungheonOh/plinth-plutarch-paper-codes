# source: src/Vesting/Contracts/VestingPlinth.hs
#
# Bug: linearVesting rewritten to derive the per-tick increment from
# the head of `[1 .. duration]`. The range desugars to
# `Prelude.enumFromTo`. The Plinth plugin rejects it with a custom
# message pointing the user at PlutusTx.Enum.enumFromTo.
#
# Apply with:
#   cp <repo>/src/Vesting/Contracts/VestingPlinth.hs <case>/Plinth.hs
#   (cd <case> && patch -p1 < Plinth.patch)
#
--- a/Plinth.hs
+++ b/Plinth.hs
@@ -152,7 +152,9 @@
 linearVesting startTimestamp duration totalAllocation timestamp
   | timestamp < startTimestamp = 0
   | timestamp > startTimestamp + duration = totalAllocation
-  | otherwise = divide (totalAllocation * (timestamp - startTimestamp)) duration
+  | otherwise = case [1 .. duration] of
+      [] -> 0
+      (x : _) -> divide (totalAllocation * (timestamp - startTimestamp)) x

